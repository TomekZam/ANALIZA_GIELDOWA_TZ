# ============================================================
# ML models – artifacts
#   - test/ i prd/ NIE wersjonujemy
#   - prezentation/ wersjonujemy (wybrane modele do prezentacji)
# ============================================================
app/ml/models/test/
app/ml/models/prd/

# Jeśli kiedykolwiek pojawi się reguła ignorująca całe app/ml/models/,
# to te wyjątki gwarantują, że prezentation będzie śledzone w GIT:
!app/ml/models/prezentation/
!app/ml/models/prezentation/**

# Demo data included in public repo
!analysis/data/
!analysis/data/wse/
!analysis/data/wse/*.csv